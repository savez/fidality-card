# Copia questo file in `.env.local` (gitignored) e popola i valori dal tuo Firebase project.
# Tutti i valori VITE_FIREBASE_* sono pubblici by design (Firebase li espone nei client web).
# Per Render: settali come Environment Variables dal dashboard del servizio.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
