---
import { meta } from '../data/meta.js'
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-links">
      <a href={meta.licenseUrl} rel="noopener noreferrer" target="_blank">MIT</a>
      <span aria-hidden="true">·</span>
      <a href={meta.contributingUrl} rel="noopener noreferrer" target="_blank">Contributing</a>
      <span aria-hidden="true">·</span>
      <a href={meta.securityUrl} rel="noopener noreferrer" target="_blank">Security</a>
      <span aria-hidden="true">·</span>
      <a href={meta.changelogUrl} rel="noopener noreferrer" target="_blank">Changelog</a>
    </div>
    <div class="footer-meta">
      <a href={meta.authorUrl} rel="noopener noreferrer" target="_blank">{meta.authorHandle}</a>
      <span aria-hidden="true">·</span>
      <span id="app-version">v{meta.version}</span>
    </div>
  </div>
</footer>

<script>
  // La versione mostrata viene dall'ultima release GitHub (tag), letta a runtime.
  // Il valore build-time (meta.version) resta come fallback se l'API non risponde.
  const KEY = 'landing:latest-release'
  const TTL_MS = 60 * 60 * 1000 // 1h, per non sbattere sul rate limit dell'API GitHub
  const API = 'https://api.github.com/repos/savez/fidality-card/releases/latest'

  function showVersion(tag) {
    const el = document.getElementById('app-version')
    if (el && tag) el.textContent = 'v' + String(tag).replace(/^v/, '')
  }

  function readCache() {
    try {
      const { v, ts } = JSON.parse(localStorage.getItem(KEY) || '{}')
      if (v && Date.now() - ts < TTL_MS) return v
    } catch {}
    return null
  }

  async function loadLatestVersion() {
    const cached = readCache()
    if (cached) {
      showVersion(cached)
      return
    }
    try {
      const res = await fetch(API, { headers: { Accept: 'application/vnd.github+json' } })
      if (!res.ok) return
      const tag = (await res.json()).tag_name
      if (!tag) return
      showVersion(tag)
      try {
        localStorage.setItem(KEY, JSON.stringify({ v: tag, ts: Date.now() }))
      } catch {}
    } catch {}
  }

  loadLatestVersion()
</script>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 2.5rem 0;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    text-align: center;
  }

  .footer-links,
  .footer-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-links a,
  .footer-meta a {
    color: var(--text);
  }

  @media (min-width: 768px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>
