{
  "name": "fidality-card",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .js,.vue",
    "lint:fix": "eslint . --ext .js,.vue --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "dexie": "^4.4.3",
    "jsbarcode": "^3.12.3",
    "pinia": "^2.3.1",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4",
    "vuetify": "^3.12.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^15.11.7",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.4",
    "sass-embedded": "^1.100.0",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^0.20.5",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^2.1.9"
  }
}
